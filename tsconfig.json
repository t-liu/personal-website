{
    "compilerOptions": {
      "target": "ES2022",
      "useDefineForClassFields": true,
  
      "module": "ESNext",
      "moduleResolution": "Bundler",
  
      "strict": true,
  
      "allowJs": true,
      "checkJs": false,
  
      "resolveJsonModule": true,
      "isolatedModules": true,
  
      "skipLibCheck": true,
  
      "noEmit": true,
  
      "types": ["vite/client"],
  
      "lib": ["ES2022", "DOM", "DOM.Iterable"]
    },
  
    "include": [
      "src/**/*.ts",
      "src/**/*.tsx",
      "src/**/*.vue",
      "vite.config.ts",
      "vite-env.d.ts"
    ]
}